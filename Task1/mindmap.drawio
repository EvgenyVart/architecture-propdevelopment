        <mxCell id="l2u80t6IFPvlUMKgaRbP-1546" value="" style="edgeStyle=none;endArrow=none;strokeWidth=3;strokeColor=#A29DC5;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="1519" target="l2u80t6IFPvlUMKgaRbP-1544">
          <mxGeometry x="-1498" y="-303.5" width="100" height="100" as="geometry">
            <mxPoint x="684" y="483.5" as="sourcePoint" />
            <mxPoint x="525" y="463.5" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l2u80t6IFPvlUMKgaRbP-1547" value="Риск оценен как &quot;Значительный&quot;, не смотря на публичность данных, всвязи с тем что данные о жилых объектак напряму связаныны с качеством подбора необходимого жилья, и в случае не качечтвенных данных компания может тебять клиентов и соответсвенно прибыль" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a29dc5;strokeColor=none;fontColor=#FFFFFF;strokeWidth=3;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="360" y="261.5" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l2u80t6IFPvlUMKgaRbP-1550" value="Риск оценен как &quot;Значительный&quot;, не смотря на публичность данных, всвязи с тем что носвости являются важным инстументом информирования, и в случает не качественных данных, могут привести к репутационным рискам и потере доверия со стороны клинта" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a29dc5;strokeColor=none;fontColor=#FFFFFF;strokeWidth=3;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="870" y="261.5" width="380" height="80" as="geometry" />
        </mxCell>
